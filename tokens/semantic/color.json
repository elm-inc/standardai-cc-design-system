{
  "color": {
    "text": {
      "primary":   { "$type": "color", "$value": "{color.neutral.800}" },
      "secondary": { "$type": "color", "$value": "{color.neutral.600}" },
      "tertiary":  { "$type": "color", "$value": "{color.neutral.500}" },
      "disabled":  { "$type": "color", "$value": "{color.neutral.400}" },
      "inverse":   { "$type": "color", "$value": "{color.neutral.0}" },
      "link":      { "$type": "color", "$value": "{color.blue.500}" },
      "linkHover": { "$type": "color", "$value": "{color.blue.600}" }
    },
    "bg": {
      "primary":   { "$type": "color", "$value": "{color.neutral.0}" },
      "secondary": { "$type": "color", "$value": "{color.neutral.50}" },
      "tertiary":  { "$type": "color", "$value": "{color.neutral.100}" },
      "inverse":   { "$type": "color", "$value": "{color.neutral.800}" }
    },
    "surface": {
      "primary":   { "$type": "color", "$value": "{color.neutral.0}" },
      "secondary": { "$type": "color", "$value": "{color.neutral.50}" },
      "elevated":  { "$type": "color", "$value": "{color.neutral.0}" }
    },
    "border": {
      "primary":  { "$type": "color", "$value": "{color.neutral.200}" },
      "secondary": { "$type": "color", "$value": "{color.neutral.300}" },
      "focus":    { "$type": "color", "$value": "{color.blue.500}" },
      "disabled": { "$type": "color", "$value": "{color.neutral.200}" }
    },
    "action": {
      "primary": {
        "default":  { "$type": "color", "$value": "{color.blue.500}" },
        "hover":    { "$type": "color", "$value": "{color.blue.400}" },
        "active":   { "$type": "color", "$value": "{color.blue.600}" },
        "disabled": { "$type": "color", "$value": "{color.blue.200}" }
      },
      "success": {
        "default":  { "$type": "color", "$value": "{color.green.400}" },
        "hover":    { "$type": "color", "$value": "{color.green.300}" },
        "active":   { "$type": "color", "$value": "{color.green.500}" }
      },
      "warning": {
        "default":  { "$type": "color", "$value": "{color.gold.400}" },
        "hover":    { "$type": "color", "$value": "{color.gold.300}" },
        "active":   { "$type": "color", "$value": "{color.gold.500}" }
      },
      "danger": {
        "default":  { "$type": "color", "$value": "{color.red.400}" },
        "hover":    { "$type": "color", "$value": "{color.red.300}" },
        "active":   { "$type": "color", "$value": "{color.red.500}" }
      }
    },
    "status": {
      "success": {
        "default": { "$type": "color", "$value": "{color.green.500}" },
        "bg":      { "$type": "color", "$value": "{color.green.50}" },
        "border":  { "$type": "color", "$value": "{color.green.200}" },
        "text":    { "$type": "color", "$value": "{color.green.600}" }
      },
      "warning": {
        "default": { "$type": "color", "$value": "{color.gold.500}" },
        "bg":      { "$type": "color", "$value": "{color.gold.50}" },
        "border":  { "$type": "color", "$value": "{color.gold.200}" },
        "text":    { "$type": "color", "$value": "{color.gold.700}" }
      },
      "danger": {
        "default": { "$type": "color", "$value": "{color.red.400}" },
        "bg":      { "$type": "color", "$value": "{color.red.50}" },
        "border":  { "$type": "color", "$value": "{color.red.200}" },
        "text":    { "$type": "color", "$value": "{color.red.600}" }
      },
      "info": {
        "default": { "$type": "color", "$value": "{color.blue.500}" },
        "bg":      { "$type": "color", "$value": "{color.blue.50}" },
        "border":  { "$type": "color", "$value": "{color.blue.200}" },
        "text":    { "$type": "color", "$value": "{color.blue.600}" }
      }
    },
    "brand": {
      "primary": { "$type": "color", "$value": "{color.brand.500}" },
      "light":   { "$type": "color", "$value": "{color.brand.100}" }
    }
  }
