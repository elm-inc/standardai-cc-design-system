{
  "fontFamily": {
    "sans": {
      "$type": "fontFamily",
      "$value": "Inter, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif"
    },
    "mono": {
      "$type": "fontFamily",
      "$value": "'JetBrains Mono', 'Fira Code', Consolas, monospace"
    }
  },
  "fontSize": {
    "2xs": { "$type": "dimension", "$value": "10px" },
    "xs":  { "$type": "dimension", "$value": "11px" },
    "sm":  { "$type": "dimension", "$value": "12px" },
    "md":  { "$type": "dimension", "$value": "14px" },
    "lg":  { "$type": "dimension", "$value": "16px" },
    "xl":  { "$type": "dimension", "$value": "18px" },
    "2xl": { "$type": "dimension", "$value": "20px" },
    "3xl": { "$type": "dimension", "$value": "24px" },
    "4xl": { "$type": "dimension", "$value": "30px" }
  },
  "fontWeight": {
    "regular":  { "$type": "fontWeight", "$value": 400 },
    "medium":   { "$type": "fontWeight", "$value": 500 },
    "semibold": { "$type": "fontWeight", "$value": 600 },
    "bold":     { "$type": "fontWeight", "$value": 700 }
  },
  "lineHeight": {
    "tight":   { "$type": "number", "$value": 1.25 },
    "normal":  { "$type": "number", "$value": 1.5 },
    "relaxed": { "$type": "number", "$value": 1.625 }
  },
  "letterSpacing": {
    "tight":  { "$type": "dimension", "$value": "-0.01em" },
    "normal": { "$type": "dimension", "$value": "0em" },
    "wide":   { "$type": "dimension", "$value": "0.025em" }
  }
}
